  "proxies": {
    "comment": "代理配置示例",
    "global": {
      "comment": "全局代理配置（所有账号默认使用）",
      "proxy_id": "global",
      "protocol": "socks5",
      "host": "127.0.0.1",
      "port": 1080,
      "username": "",
      "password": "",
      "enabled": true
    },
    "proxies": {
      "comment": "独立代理配置（可为特定账号分配）",
      "proxy_001": {
        "proxy_id": "proxy_001",
        "protocol": "http",
        "host": "proxy.example.com",
        "port": 8080,
        "username": "user123",
        "password": "pass123",
        "assigned_to": ["account_example_001"],
        "stats": {
          "response_time": 150,
          "success_count": 95,
          "failure_count": 5
        }
      },
      "proxy_002": {
        "proxy_id": "proxy_002",
        "protocol": "socks5",
        "host": "192.168.1.100",
        "port": 1080,
        "username": "",
        "password": "",
        "assigned_to": [],
        "stats": {
          "response_time": 80,
          "success_count": 100,
          "failure_count": 0
        }
      }
    }
  },

  "templates": {
    "comment": "消息模板配置示例",
    "templates": {
      "welcome": {
        "template_id": "welcome",
        "name": "欢迎消息",
        "content": "你好 {name}！欢迎加入我们的群组。当前时间：{time}",
        "category": "群组管理",
        "variables": ["name", "time"],
        "created_at": "2026-06-07T00:00:00.000000",
        "use_count": 15,
        "last_used": "2026-06-07T00:00:00.000000"
      },
      "daily_report": {
        "template_id": "daily_report",
        "name": "每日报告",
        "content": "📊 每日报告\n\n日期：{date}\n群组：{group_name}\n消息数：{message_count}\n新增成员：{new_members}",
        "category": "报告",
        "variables": ["date", "group_name", "message_count", "new_members"],
        "created_at": "2026-06-07T00:00:00.000000",
        "use_count": 5
      }
    },
    "updated_at": "2026-06-07T00:00:00.000000"
  },

  "schedules": {
    "comment": "定时任务配置示例",
    "schedules": {
      "morning_greeting": {
        "schedule_id": "morning_greeting",
        "name": "早安问候",
        "cron": "0 8 * * *",
        "action": "send_template",
        "target": "me",
        "template_id": "daily_report",
        "accounts": ["account_example_001"],
        "enabled": true,
        "created_at": "2026-06-07T00:00:00.000000",
