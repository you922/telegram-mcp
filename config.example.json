        "lastRun": "2026-06-07T08:00:00.000000",
        "next_run": "2026-06-07T08:00:00.000000",
        "run_count": 2,
        "fail_count": 0
      },
      "weekly_summary": {
        "schedule_id": "weekly_summary",
        "name": "每周总结",
        "cron": "0 18 * * 0",
        "action": "send_message",
        "target": "@my_channel",
        "message": "本周工作总结：...",
        "accounts": null,
        "enabled": true,
        "created_at": "2026-06-07T00:00:00.000000",
